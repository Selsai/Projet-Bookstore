<!DOCTYPE html>
<html lang="fr">

<head>

<meta charset="UTF-8">

<title>Bibliothèque</title>

<link rel="stylesheet" href="/styles/main.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>

<!-- SHAPES -->

<div class="floating-shape shape1"></div>
<div class="floating-shape shape2"></div>
<div class="floating-shape shape3"></div>

<div class="container">

<!-- HEADER -->

<div class="top-bar">

<div>

<h1 class="page-title">
Bibliothèque
</h1>

<p class="subtitle">
Votre collection personnelle de livres
</p>

<div class="poetic-line">
✿ Des histoires, des émotions, des souvenirs entre les pages ✿
</div>

</div>

<a href="/add" class="btn-primary">
<i class="fa-solid fa-plus"></i>
Ajouter un livre
</a>

</div>

<!-- STATS -->

<div class="stats-card card">

<div>
<strong><%= books.length %></strong>
livre(s)
</div>

<input
type="text"
id="searchBooks"
placeholder="Rechercher un livre..."
class="input-field search-input">

</div>

<!-- EMPTY STATE -->

<% if (books.length === 0) { %>

<div class="card empty-state">

<i class="fa-solid fa-book-open empty-icon"></i>

<h2>
Aucun livre enregistré
</h2>

<p class="subtitle">
Commencez votre collection poétique.
</p>

</div>

<% } %>

<!-- BOOK GRID -->

<div class="book-grid">

<% books.forEach(book => { %>

<div class="book-card searchable">

<div class="book-id">
ID : <%= book.id %>
</div>

<h2 class="book-title">
<%= book.title %>
</h2>

<p class="book-author">
<%= book.author %>
</p>

<p class="book-description">
<%= book.description || 'Aucune description.' %>
</p>

<div class="actions">

<a
href="/edit/<%= book.id %>"
class="edit-link">

<i class="fa-solid fa-pen"></i>
Modifier

</a>

<a
href="/delete/<%= book.id %>"
class="delete-link delete-btn">

<i class="fa-solid fa-trash"></i>
Supprimer

</a>

</div>

</div>

<% }) %>

</div>

<!-- QUOTE -->

<div class="quote-box" id="quoteBox"></div>

<!-- FOOTER -->

<div class="footer">
Bookstore • Express • LoopBack 4 • MongoDB
</div>

</div>

<!-- MODAL -->

<div class="modal" id="deleteModal">

<div class="modal-content">

<h2 class="modal-title">
Supprimer ce livre ?
</h2>

<p class="modal-text">
Êtes-vous sûr de quitter l’univers Book ?
</p>

<div class="modal-actions">

<button
class="btn-secondary"
id="cancelDelete">

Annuler

</button>

<a
href="#"
class="btn-primary"
id="confirmDelete">

Confirmer

</a>

</div>

</div>

</div>

<!-- TOAST -->

<div class="toast" id="toast">
Livre supprimé avec succès
</div>

<!-- SCRIPT -->

<script>

/* =========================
   MODAL DELETE
========================= */

const modal = document.getElementById('deleteModal');

const confirmBtn =
document.getElementById('confirmDelete');

const cancelBtn =
document.getElementById('cancelDelete');

const toast =
document.getElementById('toast');

let deleteUrl = '';

document
.querySelectorAll('.delete-btn')
.forEach(btn => {

btn.addEventListener('click', function(e){

e.preventDefault();

deleteUrl = this.href;

modal.classList.add('active');

});

});

/* CANCEL */

cancelBtn.addEventListener('click', () => {

modal.classList.remove('active');

});

/* CONFIRM */

confirmBtn.addEventListener('click', function(e){

e.preventDefault();

toast.classList.add('show');

setTimeout(() => {

window.location.href = deleteUrl;

},500);

});

/* =========================
   SEARCH
========================= */

const search =
document.getElementById('searchBooks');

if(search){

search.addEventListener('keyup', () => {

const value =
search.value.toLowerCase();

document
.querySelectorAll('.searchable')
.forEach(card => {

const text =
card.innerText.toLowerCase();

card.style.display =
text.includes(value)
? 'block'
: 'none';

});

});

}

/* =========================
   QUOTES
========================= */

const quotes = [

"Les livres sont des jardins qu'on transporte avec soi.",

"Chaque page tournée est une nouvelle aventure.",

"Les mots ont le pouvoir de faire fleurir l'âme.",

"Lire, c’est rêver les yeux ouverts.",

"Les histoires rendent la vie plus douce."

];

const quoteBox =
document.getElementById('quoteBox');

if(quoteBox){

quoteBox.innerText =
quotes[
Math.floor(
Math.random() * quotes.length
)
];

}

/* =========================
   PAGE TRANSITION
========================= */

document
.querySelectorAll('a')
.forEach(link => {

link.addEventListener('click', function(e){

if(
this.classList.contains('delete-btn')
){
return;
}

const href =
this.getAttribute('href');

if(
href &&
!href.startsWith('#')
){

e.preventDefault();

document.body.style.opacity = '.6';

setTimeout(() => {

window.location = href;

},180);

}

});

});

</script>

</body>
</html>